import { useState, useEffect } from "react";
import { useNavigate } from "react-router-dom";
import { useForm } from "@tanstack/react-form";
import { zodValidator } from "@tanstack/zod-form-adapter";
import {
  AlertTriangle,
  MapPin,
  Camera,
  Send,
  ChevronRight,
  ChevronLeft,
  User,
  Phone,
  Mail,
  FileText,
  Shield,
  Navigation,
  Clock,
  Loader2,
} from "lucide-react";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Textarea } from "@/components/ui/textarea";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import AppHeader from "@/components/AppHeader";
import { useIncidentStore } from "@/context/IncidentStore";
import {
  createBackendAccidentReport,
  mapBackendAccidentToIncident,
} from "@/lib/backend-api";
import {
  INCIDENT_TYPES,
  SEVERITY_LEVELS,
  IncidentType,
  SeverityLevel,
} from "@/types/incident";
import { generateReportId } from "@/lib/incident-utils";
import { toast } from "sonner";
import { reportFormSchema, ReportFormValues } from "@/lib/validation-schemas";

const stepConfig = [
  {
    title: "Reporter Info",
    eyebrow: "Step 01",
    description:
      "Identify who is reporting so dispatch can call back if more detail is needed.",
    icon: User,
  },
  {
    title: "Accident Details",
    eyebrow: "Step 02",
    description:
      "Describe what happened, set severity, and capture the core accident facts.",
    icon: AlertTriangle,
  },
  {
    title: "Location",
    eyebrow: "Step 03",
    description:
      "Pin down the exact scene so the nearest unit can reach it without delay.",
    icon: MapPin,
  },
  {
    title: "Evidence & Submit",
    eyebrow: "Step 04",
    description:
      "Confirm timing, attach supporting media, and dispatch the report into the live queue.",
    icon: Camera,
  },
] as const;

const severityStyles: Record<SeverityLevel, string> = {
  Critical:
    "border-severity-critical/40 bg-severity-critical/15 text-primary-foreground",
  High: "border-severity-high/40 bg-severity-high/15 text-primary-foreground",
  Medium: "border-severity-medium/40 bg-severity-medium/15 text-foreground",
  Low: "border-severity-low/40 bg-severity-low/15 text-primary-foreground",
};

export default function ReportPage() {
  const navigate = useNavigate();
  const { addIncident } = useIncidentStore();
  const [step, setStep] = useState(0);
  const [locationAttempted, setLocationAttempted] = useState(false);

  const form = useForm<ReportFormValues>({
    defaultValues: {
      reporter_name: "",
      phone_number: "",
      email: "",
      incident_type: "",
      severity_level: "",
      short_description: "",
      number_of_victims: "0",
      vehicles_involved: "0",
      gps_latitude: "",
      gps_longitude: "",
      location_address: "",
      time_of_incident: "",
      photos: [],
    },
    validatorAdapter: zodValidator(),
    onSubmit: async ({ value }) => {
      try {
        console.log("[REPORT SUBMIT] Submitting report:", value);

        // Generate report ID
        const id = generateReportId();

        // Try to create backend accident report
        const accidentData = {
          reporter_name: value.reporter_name,
          phone_number: value.phone_number,
          email: value.email,
          incident_type: value.incident_type,
          severity_level: value.severity_level,
          short_description: value.short_description,
          number_of_victims: parseInt(value.number_of_victims),
          vehicles_involved: parseInt(value.vehicles_involved),
          gps_latitude: parseFloat(value.gps_latitude),
          gps_longitude: parseFloat(value.gps_longitude),
          location_address: value.location_address,
          time_of_incident: value.time_of_incident,
        };

        console.log("[REPORT SUBMIT] Accident data:", accidentData);

        try {
          const response = await createBackendAccidentReport(accidentData);
          console.log("[REPORT SUBMIT] Backend response:", response);

          const incident = mapBackendAccidentToIncident(response);
          addIncident(incident);
          console.log("[REPORT SUBMIT] Successfully saved incident:", incident);

          toast.success("Report submitted successfully!");
          navigate("/user-dashboard");
        } catch (backendError) {
          console.warn("[REPORT SUBMIT] Backend error, using fallback:", backendError);

          // Fallback: save to local store
          const incident = {
            id,
            type: value.incident_type as IncidentType,
            severity: value.severity_level as SeverityLevel,
            location: value.location_address,
            latitude: parseFloat(value.gps_latitude),
            longitude: parseFloat(value.gps_longitude),
            description: value.short_description,
            reported_by: value.reporter_name,
            timestamp: new Date(value.time_of_incident),
            lastUpdated: new Date(),
            status: "SUBMITTED" as const,
          };

          addIncident(incident);
          toast.success("Report submitted!");
          navigate("/user-dashboard");
        }
      } catch (err) {
        console.error("[REPORT SUBMIT] Error:", err);
        toast.error("Failed to submit report. Please try again.");
      }
    },
  });

  // Auto-detect location
  const getLocationAuto = () => {
    if (!navigator.geolocation) {
      toast.error("Geolocation is not supported on this device");
      setLocationAttempted(true);
      return;
    }

    navigator.geolocation.getCurrentPosition(
      (pos) => {
        form.setFieldValue("gps_latitude", String(pos.coords.latitude));
        form.setFieldValue("gps_longitude", String(pos.coords.longitude));
        setLocationAttempted(true);
        toast.success("✓ Location automatically captured");
      },
      (error) => {
        setLocationAttempted(true);
        const messages: Record<number, string> = {
          1: "Location permission denied. Please allow access to use auto-detect.",
          2: "Position unavailable. Please enter location manually.",
          3: "Location request timed out. Please try again.",
        };
        toast.error(messages[error.code] || "Could not get location");
      },
      {
        enableHighAccuracy: true,
        timeout: 8000,
        maximumAge: 0,
      }
    );
  };

  // Auto-detect location when reaching step 2 (Location step)
  useEffect(() => {
    if (step === 2 && !locationAttempted) {
      getLocationAuto();
    }
  }, [step, locationAttempted]);

  const currentStep = stepConfig[step];
      errors.severity_level = "Severity level is required";
    }

    if (!form.short_description.trim()) {
      errors.short_description = "Description is required";
    }

    if (!form.time_of_incident) {
      errors.time_of_incident = "Time of incident is required";
    }

    // Validate location coordinates
    const lat = form.gps_latitude ? parseFloat(form.gps_latitude) : 0;
    const lng = form.gps_longitude ? parseFloat(form.gps_longitude) : 0;

    if (!isLocationValid()) {
      errors.gps_latitude = "Invalid GPS coordinates. Use auto-detect or enter valid coordinates";
    }

    // If there are errors, display them and prevent submission
    if (Object.keys(errors).length > 0) {
      setFormErrors(errors);
      toast.error(`Please fill in all required fields (${Object.keys(errors).length} errors)`);
      return;
    }

    const now = new Date().toISOString();
    const userEmail = form.email.trim() || `reporter-${Date.now()}@swift.local`;

    setIsSubmitting(true);

    try {
      console.log("[REPORT SUBMIT] Starting submission...");
      const result = await createBackendAccidentReport({
        description: form.short_description.trim(),
        severity: form.severity_level || "Medium",
        latitude: lat || 0,
        longitude: lng || 0,
        locationAddress: form.location_address.trim(),
        accidentDate: form.time_of_incident
          ? new Date(form.time_of_incident).toISOString()
          : now,
        reporterName: form.reporter_name.trim(),
        reporterEmail: userEmail,
        phoneNumber: form.phone_number.trim(),
        numberOfVehicles: form.vehicles_involved
          ? Number(form.vehicles_involved)
          : undefined,
        numberOfInjuries: form.number_of_victims
          ? Number(form.number_of_victims)
          : undefined,
      });

      console.log("[REPORT SUBMIT] Backend response:", result);
      const backendData = result?.accident;
      const backendIncident = mapBackendAccidentToIncident(backendData);

      addIncident({
        ...backendIncident,
        report_id: backendIncident.report_id || id,
        reporter_name: form.reporter_name.trim(),
        phone_number: form.phone_number.trim(),
        email: userEmail,
        incident_type: form.incident_type || backendIncident.incident_type,
        severity_level: form.severity_level || backendIncident.severity_level,
        short_description: form.short_description.trim(),
        number_of_victims: form.number_of_victims
          ? Number(form.number_of_victims)
          : undefined,
        vehicles_involved: form.vehicles_involved
          ? Number(form.vehicles_involved)
          : undefined,
        photos: [],
        time_of_incident: form.time_of_incident
          ? new Date(form.time_of_incident).toISOString()
          : now,
        time_report_submitted: backendIncident.time_report_submitted,
        created_at: backendIncident.created_at,
        updated_at: backendIncident.updated_at,
      });

      console.log("[REPORT SUBMIT] Successfully added to incident store");
      toast.success(
        `Accident ${backendIncident.report_id} submitted successfully!`,
      );
      setTimeout(() => navigate("/user-dashboard"), 2000);
    } catch (error) {
      // Fallback to local storage
      console.error("[REPORT SUBMIT] Backend error, using fallback:", error);
      const now = new Date().toISOString();
      addIncident({
        report_id: id,
        status: "Submitted",
        reporter_name: form.reporter_name.trim(),
        phone_number: form.phone_number.trim(),
        email: userEmail,
        incident_type: form.incident_type || "Other",
        severity_level: form.severity_level || "Medium",
        short_description: form.short_description.trim(),
        number_of_victims: form.number_of_victims
          ? Number(form.number_of_victims)
          : undefined,
        vehicles_involved: form.vehicles_involved
          ? Number(form.vehicles_involved)
          : undefined,
        gps_latitude: lat || 0,
        gps_longitude: lng || 0,
        location_address: form.location_address.trim(),
        photos: [],
        time_of_incident: form.time_of_incident
          ? new Date(form.time_of_incident).toISOString()
          : now,
        time_report_submitted: now,
        created_at: now,
        updated_at: now,
      });

      console.log("[REPORT SUBMIT] Fallback incident added:", id);
      toast.error(
        error instanceof Error
          ? `Backend submission failed. Stored locally: ${error.message}`
          : "Backend submission failed. Stored locally.",
      );
      setTimeout(() => navigate("/user-dashboard"), 2000);
    } finally {
      console.log("[REPORT SUBMIT] Submission complete, isSubmitting = false");
      setIsSubmitting(false);
    }
  };

  return (
    <div className="min-h-screen bg-background">
      <AppHeader
        brandTo="/report"
        brandLabel="Accident Report"
        navItems={reportNavItems}
        userBadge="PR"
      />

      <div className="relative overflow-hidden">
        <div className="absolute inset-0 grid-pattern opacity-25" />
        <div className="absolute left-[-8rem] top-20 h-64 w-64 rounded-full bg-primary/10 blur-3xl" />
        <div className="absolute right-[-6rem] top-32 h-72 w-72 rounded-full bg-warning/10 blur-3xl" />

        <div className="relative mx-auto max-w-7xl px-4 py-8 md:py-12">
          <div className="mb-8 max-w-3xl">
            <div className="mb-4 inline-flex items-center gap-2 rounded-full border border-border/70 bg-card/70 px-4 py-2 backdrop-blur-sm">
              <AlertTriangle className="h-4 w-4 text-primary" />
              <span className="font-mono text-[11px] uppercase tracking-[0.28em] text-primary">
                Emergency Intake
              </span>
            </div>
            <h1 className="text-3xl font-black tracking-tight text-foreground md:text-5xl">
              Report an accident with enough detail for an immediate response
            </h1>
            <p className="mt-4 max-w-2xl text-base leading-7 text-muted-foreground md:text-lg">
              Move through the intake steps, give dispatch usable facts, and
              send a structured accident report directly into the live queue.
            </p>
          </div>

          <div className="grid gap-6 lg:grid-cols-[300px_minmax(0,1fr)]">
            <aside className="space-y-4 lg:sticky lg:top-20 lg:self-start">
              <Card className="overflow-hidden border-border/80 bg-card/85 backdrop-blur-sm">
                <div className="h-24 bg-gradient-to-b from-primary/20 via-info/10 to-transparent" />
                <CardContent className="relative -mt-10 p-6">
                  <div className="flex h-14 w-14 items-center justify-center rounded-2xl border border-border/70 bg-secondary/85 shadow-inner">
                    <currentStep.icon className="h-6 w-6 text-primary" />
                  </div>
                  <div className="mt-4">
                    <p className="font-mono text-[11px] uppercase tracking-[0.26em] text-primary">
                      {currentStep.eyebrow}
                    </p>
                    <h2 className="mt-2 text-xl font-semibold text-foreground">
                      {currentStep.title}
                    </h2>
                    <p className="mt-2 text-sm leading-6 text-muted-foreground">
                      {currentStep.description}
                    </p>
                  </div>

                  <div className="mt-6 space-y-3">
                    {stepConfig.map((item, index) => (
                      <button
                        key={item.title}
                        type="button"
                        className={`flex w-full items-start gap-3 rounded-2xl border p-3 text-left transition-colors ${
                          index === step
                            ? "border-primary/30 bg-primary/10"
                            : index < step
                              ? "border-border/70 bg-secondary/60 hover:bg-secondary/80"
                              : "border-border/50 bg-background/40"
                        }`}
                        onClick={() => {
                          if (index <= step) {
                            setStep(index);
                          }
                        }}
                      >
                        <div
                          className={`mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-xl border ${
                            index === step
                              ? "border-primary/30 bg-primary text-primary-foreground"
                              : "border-border/70 bg-secondary/80 text-muted-foreground"
                          }`}
                        >
                          <span className="font-mono text-xs">
                            {String(index + 1).padStart(2, "0")}
                          </span>
                        </div>
                        <div>
                          <p className="text-sm font-medium text-foreground">
                            {item.title}
                          </p>
                          <p className="mt-1 text-xs leading-5 text-muted-foreground">
                            {item.description}
                          </p>
                        </div>
                      </button>
                    ))}
                  </div>
                </CardContent>
              </Card>

              <Card className="border-border/80 bg-card/80 backdrop-blur-sm">
                <CardHeader className="pb-4">
                  <div className="flex items-center justify-between gap-3">
                    <div>
                      <p className="font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">
                        Accident Draft
                      </p>
                      <CardTitle className="mt-2 text-lg text-foreground">
                        Submission progress
                      </CardTitle>
                    </div>
                    <div className="rounded-full border border-border/70 bg-secondary/70 px-3 py-1 font-mono text-xs text-primary">
                      {completionPct}%
                    </div>
                  </div>
                  <CardDescription>
                    Required fields filled across the full intake flow.
                  </CardDescription>
                </CardHeader>
                <CardContent className="space-y-4">
                  <div className="h-2 overflow-hidden rounded-full bg-secondary">
                    <div
                      className="h-full rounded-full bg-gradient-to-r from-primary via-info to-accent"
                      style={{ width: `${completionPct}%` }}
                    />
                  </div>

                  <div className="space-y-3 text-sm">
                    <SummaryRow
                      label="Reporter"
                      value={form.reporter_name || "Not added"}
                    />
                    <SummaryRow
                      label="Type"
                      value={form.incident_type || "Not selected"}
                    />
                    <SummaryRow
                      label="Severity"
                      value={form.severity_level || "Not selected"}
                    />
                    <SummaryRow
                      label="Location"
                      value={form.location_address || "Not pinned"}
                    />
                  </div>
                </CardContent>
              </Card>

              <Card className="border-border/80 bg-card/80 backdrop-blur-sm">
                <CardContent className="p-5">
                  <div className="flex items-start gap-3">
                    <div className="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl border border-border/70 bg-secondary/80">
                      <Shield className="h-5 w-5 text-info" />
                    </div>
                    <div>
                      <h3 className="text-sm font-semibold text-foreground">
                        Dispatch quality tips
                      </h3>
                      <p className="mt-2 text-sm leading-6 text-muted-foreground">
                        Keep descriptions factual and confirm the exact address
                        before submitting.
                      </p>
                    </div>
                  </div>
                </CardContent>
              </Card>
            </aside>

            <Card className="overflow-hidden border-border/80 bg-card/85 backdrop-blur-sm">
              <div className="h-28 bg-gradient-to-b from-primary/18 via-info/8 to-transparent" />
              <CardHeader className="relative -mt-10 pb-4">
                <div className="flex items-center gap-3">
                  <div className="flex h-12 w-12 items-center justify-center rounded-2xl border border-border/70 bg-secondary/85">
                    <currentStep.icon className="h-5 w-5 text-primary" />
                  </div>
                  <div>
                    <p className="font-mono text-[11px] uppercase tracking-[0.26em] text-primary">
                      {currentStep.eyebrow}
                    </p>
                    <CardTitle className="mt-2 text-2xl text-foreground">
                      {currentStep.title}
                    </CardTitle>
                  </div>
                </div>
                <CardDescription className="mt-3 max-w-2xl text-sm leading-6">
                  {currentStep.description}
                </CardDescription>
              </CardHeader>

              <CardContent className="space-y-6">
                {step === 0 && (
                  <>
                    <div className="grid gap-4 md:grid-cols-2">
                      <FieldShell label="Full Name *" error={formErrors.reporter_name}>
                        <div className="relative">
                          <User className="absolute left-3 top-2.5 h-4 w-4 text-muted-foreground" />
                          <Input
                            className={`border-border bg-secondary pl-10 text-foreground ${
                              formErrors.reporter_name ? "border-destructive" : ""
                            }`}
                            placeholder="Your full name"
                            value={form.reporter_name}
                            onChange={(e) =>
                              update("reporter_name", e.target.value)
                            }
                          />
                        </div>
                      </FieldShell>

                      <FieldShell label="Phone Number *" error={formErrors.phone_number}>
                        <div className="relative">
                          <Phone className="absolute left-3 top-2.5 h-4 w-4 text-muted-foreground" />
                          <Input
                            className={`border-border bg-secondary pl-10 text-foreground ${
                              formErrors.phone_number ? "border-destructive" : ""
                            }`}
                            placeholder="+234..."
                            value={form.phone_number}
                            onChange={(e) =>
                              update("phone_number", e.target.value)
                            }
                          />
                        </div>
                      </FieldShell>
                    </div>

                    <FieldShell label="Email (optional)">
                      <div className="relative">
                        <Mail className="absolute left-3 top-2.5 h-4 w-4 text-muted-foreground" />
                        <Input
                          className="border-border bg-secondary pl-10 text-foreground"
                          placeholder="your@email.com"
                          value={form.email}
                          onChange={(e) => update("email", e.target.value)}
                        />
                      </div>
                    </FieldShell>

                    <div className="rounded-2xl border border-border/70 bg-secondary/55 p-4 text-sm leading-6 text-muted-foreground">
                      Witness/victim role capture was removed from the main flow
                      to match the backend accident schema more closely.
                    </div>
                  </>
                )}

                {step === 1 && (
                  <>
                    <div className="grid gap-4 md:grid-cols-[minmax(0,1fr)_180px]">
                      <FieldShell label="Accident Type *" error={formErrors.incident_type}>
                        <Select
                          value={form.incident_type}
                          onValueChange={(value) =>
                            update("incident_type", value)
                          }
                        >
                          <SelectTrigger className={`border-border bg-secondary text-foreground ${
                            formErrors.incident_type ? "border-destructive" : ""
                          }`}>
                            <SelectValue placeholder="Select type" />
                          </SelectTrigger>
                          <SelectContent>
                            {INCIDENT_TYPES.map((type) => (
                              <SelectItem key={type} value={type}>
                                {type}
                              </SelectItem>
                            ))}
                          </SelectContent>
                        </Select>
                      </FieldShell>

                      <FieldShell label="Time Sensitivity">
                        <div className="rounded-2xl border border-border/70 bg-secondary/55 p-4 text-sm text-muted-foreground">
                          {form.severity_level === "Critical"
                            ? "Immediate dispatch required"
                            : form.severity_level === "High"
                              ? "Rapid response recommended"
                              : form.severity_level === "Medium"
                                ? "Operational review needed"
                                : form.severity_level === "Low"
                                  ? "Monitor and assign normally"
                                  : "Select severity to estimate urgency"}
                        </div>
                      </FieldShell>
                    </div>

                    <div className="space-y-3">
                      <Label className="text-foreground">
                        Severity Level * {formErrors.severity_level && <span className="text-destructive text-xs ml-2">{formErrors.severity_level}</span>}
                      </Label>
                      <div className="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                        {SEVERITY_LEVELS.map((severity) => {
                          const active = form.severity_level === severity;
                          return (
                            <button
                              key={severity}
                              type="button"
                              className={`rounded-2xl border p-4 text-left transition-all ${
                                active
                                  ? severityStyles[severity]
                                  : formErrors.severity_level
                                    ? "border-destructive/40 bg-secondary/55 text-foreground hover:bg-secondary/80"
                                    : "border-border/70 bg-secondary/55 text-foreground hover:bg-secondary/80"
                              }`}
                              onClick={() => update("severity_level", severity)}
                            >
                              <div className="flex items-center justify-between gap-3">
                                <span className="text-sm font-semibold">
                                  {severity}
                                </span>
                                {active && (
                                  <div className="h-2.5 w-2.5 rounded-full bg-current" />
                                )}
                              </div>
                            </button>
                          );
                        })}
                      </div>
                    </div>

                    <FieldShell label="Description *" error={formErrors.short_description}>
                      <Textarea
                        className={`min-h-[140px] border-border bg-secondary text-foreground ${
                          formErrors.short_description ? "border-destructive" : ""
                        }`}
                        placeholder="Describe the accident, the affected vehicles, and the current scene..."
                        value={form.short_description}
                        onChange={(e) =>
                          update("short_description", e.target.value)
                        }
                      />
                    </FieldShell>

                    <div className="grid gap-4 md:grid-cols-3">
                      <FieldShell label="Injuries">
                        <Input
                          className="border-border bg-secondary text-foreground"
                          type="number"
                          min={0}
                          placeholder="0"
                          value={form.number_of_victims}
                          onChange={(e) =>
                            update("number_of_victims", e.target.value)
                          }
                        />
                      </FieldShell>

                      <FieldShell label="Vehicles">
                        <Input
                          className="border-border bg-secondary text-foreground"
                          type="number"
                          min={0}
                          value={form.vehicles_involved}
                          onChange={(e) =>
                            update("vehicles_involved", e.target.value)
                          }
                        />
                      </FieldShell>

                      <div className="rounded-2xl border border-border/70 bg-secondary/55 p-4 text-sm leading-6 text-muted-foreground">
                        Injury detail notes were removed from the structured
                        form because the backend only stores the injury count
                        directly.
                      </div>
                    </div>
                  </>
                )}

                {step === 2 && (
                  <>
                    <Card className="border-border/80 bg-secondary/45">
                      <CardContent className="p-5">
                        <div className="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                          <div>
                            <p className="text-sm font-semibold text-foreground">
                              Locate the accident scene
                            </p>
                            <p className="mt-1 text-sm leading-6 text-muted-foreground">
                              Use GPS if available, then confirm the address
                              that should be sent to the backend.
                            </p>
                            {form.gps_latitude && form.gps_longitude && isLocationValid() && (
                              <p className="mt-2 text-xs text-green-500 dark:text-green-400 flex items-center gap-1">
                                ✓ GPS coordinates captured
                              </p>
                            )}
                          </div>
                          <Button
                            type="button"
                            onClick={getLocation}
                            className="border border-border bg-background text-foreground hover:bg-secondary gap-2"
                          >
                            <Navigation className="h-4 w-4 text-primary" />
                            Re-detect location
                          </Button>
                        </div>
                      </CardContent>
                    </Card>

                    <div className="grid gap-4 md:grid-cols-2">
                      <FieldShell label="Latitude" error={formErrors.gps_latitude}>
                        <Input
                          className={`border-border bg-secondary font-mono text-foreground ${
                            formErrors.gps_latitude ? "border-destructive" : ""
                          }`}
                          placeholder="Auto-detected or enter manually"
                          value={form.gps_latitude}
                          onChange={(e) =>
                            update("gps_latitude", e.target.value)
                          }
                        />
                      </FieldShell>

                      <FieldShell label="Longitude">
                        <Input
                          className="border-border bg-secondary font-mono text-foreground"
                          placeholder="Auto-detected or enter manually"
                          value={form.gps_longitude}
                          onChange={(e) =>
                            update("gps_longitude", e.target.value)
                          }
                        />
                      </FieldShell>
                    </div>

                    <FieldShell label="Address *" error={formErrors.location_address}>
                      <Input
                        className={`border-border bg-secondary text-foreground ${
                          formErrors.location_address ? "border-destructive" : ""
                        }`}
                        placeholder="Street address"
                        value={form.location_address}
                        onChange={(e) =>
                          update("location_address", e.target.value)
                        }
                      />
                    </FieldShell>

                    <div className="rounded-2xl border border-border/70 bg-secondary/55 p-4 text-sm leading-6 text-muted-foreground">
                      Landmark capture was removed from the main backend flow.
                      Use the description field if extra location context is
                      needed.
                    </div>
                  </>
                )}

                {step === 3 && (
                  <>
                    <div className="grid gap-4 xl:grid-cols-[minmax(0,1fr)_320px]">
                      <div className="space-y-4">
                        <FieldShell label="Time of Accident" error={formErrors.time_of_incident}>
                          <div className="relative">
                            <Clock className="absolute left-3 top-2.5 h-4 w-4 text-muted-foreground" />
                            <Input
                              className={`border-border bg-secondary pl-10 text-foreground ${
                                formErrors.time_of_incident ? "border-destructive" : ""
                              }`}
                              type="datetime-local"
                              value={form.time_of_incident}
                              onChange={(e) =>
                                update("time_of_incident", e.target.value)
                              }
                            />
                          </div>
                        </FieldShell>

                        <FieldShell label="Upload Photos">
                          <div className="space-y-3">
                            <label className="block">
                              <input
                                type="file"
                                multiple
                                accept="image/*"
                                onChange={handlePhotoUpload}
                                className="hidden"
                              />
                              <div className="cursor-pointer rounded-2xl border-2 border-dashed border-border bg-secondary/50 p-8 transition-colors hover:border-primary/30">
                                <div className="text-center">
                                  <Camera className="mx-auto h-8 w-8 text-muted-foreground" />
                                  <p className="mt-3 text-sm font-medium text-foreground">
                                    Click to upload scene photos
                                  </p>
                                  <p className="mt-1 text-xs text-muted-foreground">
                                    JPG or PNG up to 10MB each (max 5)
                                  </p>
                                </div>
                              </div>
                            </label>
                            {form.photos.length > 0 && (
                              <div className="space-y-2">
                                <p className="text-sm font-medium text-foreground">
                                  {form.photos.length} photo(s) selected
                                </p>
                                <div className="space-y-2">
                                  {form.photos.map((file, index) => (
                                    <div
                                      key={`${file.name}-${index}`}
                                      className="flex items-center justify-between rounded-lg border border-border/70 bg-secondary/60 p-3"
                                    >
                                      <span className="text-sm text-foreground">
                                        {file.name}
                                      </span>
                                      <Button
                                        type="button"
                                        variant="ghost"
                                        size="sm"
                                        onClick={() => removePhoto(index)}
                                        className="text-destructive hover:bg-destructive/10"
                                      >
                                        Remove
                                      </Button>
                                    </div>
                                  ))}
                                </div>
                              </div>
                            )}
                          </div>
                        </FieldShell>
                      </div>

                      <Card className="border-border/80 bg-secondary/45">
                        <CardHeader>
                          <div className="flex items-center gap-3">
                            <div className="flex h-10 w-10 items-center justify-center rounded-2xl border border-border/70 bg-background/60">
                              <FileText className="h-5 w-5 text-primary" />
                            </div>
                            <div>
                              <CardTitle className="text-lg text-foreground">
                                Accident Summary
                              </CardTitle>
                              <CardDescription>
                                Final review before dispatch.
                              </CardDescription>
                            </div>
                          </div>
                        </CardHeader>
                        <CardContent className="space-y-3 text-sm">
                          <SummaryRow
                            label="Reporter"
                            value={form.reporter_name || "—"}
                          />
                          <SummaryRow
                            label="Type"
                            value={form.incident_type || "—"}
                          />
                          <SummaryRow
                            label="Severity"
                            value={form.severity_level || "—"}
                          />
                          <SummaryRow
                            label="Location"
                            value={form.location_address || "—"}
                          />
                          <SummaryRow
                            label="Injuries"
                            value={form.number_of_victims || "0"}
                          />
                          <SummaryRow
                            label="Vehicles"
                            value={form.vehicles_involved || "0"}
                          />
                        </CardContent>
                      </Card>
                    </div>
                  </>
                )}
              </CardContent>

              <CardFooter className="flex items-center justify-between gap-3 border-t border-border/70 pt-6">
                <Button
                  type="button"
                  variant="outline"
                  className="border-border text-foreground"
                  disabled={step === 0}
                  onClick={() =>
                    setStep((currentStepIndex) => currentStepIndex - 1)
                  }
                >
                  <ChevronLeft className="mr-1 h-4 w-4" />
                  Back
                </Button>

                <div className="flex items-center gap-3">
                  <span className="hidden text-sm text-muted-foreground sm:inline">
                    Step {step + 1} of {stepConfig.length}
                  </span>
                  {step < stepConfig.length - 1 ? (
                    <Button
                      type="button"
                      className="bg-primary text-primary-foreground hover:bg-primary/90"
                      onClick={() => {
                        if (validateStep()) {
                          setStep((currentStepIndex) => currentStepIndex + 1);
                        }
                      }}
                    >
                      Continue
                      <ChevronRight className="ml-1 h-4 w-4" />
                    </Button>
                  ) : (
                    <Button
                      type="button"
                      className="bg-primary text-primary-foreground hover:bg-primary/90 gap-2"
                      disabled={isSubmitting}
                      onClick={handleSubmit}
                    >
                      {isSubmitting ? (
                        <>
                          <Loader2 className="h-4 w-4 animate-spin" />
                          Submitting...
                        </>
                      ) : (
                        <>
                          <Send className="h-4 w-4" />
                          Submit Accident
                        </>
                      )}
                    </Button>
                  )}
                </div>
              </CardFooter>
            </Card>
          </div>
        </div>
      </div>
    </div>
  );
}

function FieldShell({
  label,
  error,
  children,
}: {
  label: string;
  error?: string;
  children: React.ReactNode;
}) {
  return (
    <div className="space-y-2">
      <Label className="text-foreground">{label}</Label>
      {children}
      {error && <p className="text-xs text-destructive mt-1">{error}</p>}
    </div>
  );
}

function SummaryRow({ label, value }: { label: string; value: string }) {
  return (
    <div className="flex items-start justify-between gap-4">
      <span className="shrink-0 text-muted-foreground">{label}</span>
      <span className="text-right text-foreground">{value}</span>
    </div>
  );
}
